generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                       String            @id @default(uuid())
  email                    String            @unique
  password                 String
  name                     String?
  plan                     Plan              @default(free)
  createdAt                DateTime          @default(now()) @map("created_at")
  updatedAt                DateTime          @updatedAt @map("updated_at")
  trialEndsAt              DateTime          @map("trial_ends_at")
  stripeCustomerId         String?           @map("stripe_customer_id")
  stripeSubscriptionId     String?           @map("stripe_subscription_id")
  stripeSubscriptionStatus String?           @map("stripe_subscription_status")
  appointments             Appointment[]
  catalogCategories        CatalogCategory[]
  catalogProducts          CatalogProduct[]
  financeCategories        FinanceCategory[]
  leads                    Lead[]
  refreshTokens            RefreshToken[]
  transactions             Transaction[]

  @@map("users")
}

model RefreshToken {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  token      String    @unique
  deviceName String?   @map("device_name")
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Lead {
  id            String        @id @default(uuid())
  userId        String        @map("user_id")
  name          String
  phone         String
  cpfCnpj       String?       @map("cpf_cnpj")
  email         String?
  origin        LeadOrigin    @default(outro)
  location      String?
  observations  String?
  recurringSale Boolean       @default(false) @map("recurring_sale")
  funnelStage   FunnelStage   @default(novo) @map("funnel_stage")
  dealValue     Decimal?      @map("deal_value") @db.Decimal(10, 2)
  lostReason    String?       @map("lost_reason")
  deletedAt     DateTime?     @map("deleted_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  appointments  Appointment[]
  leadProducts  LeadProduct[]
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("leads")
}

model Appointment {
  id          String          @id @default(uuid())
  userId      String          @map("user_id")
  leadId      String?         @map("lead_id")
  title       String
  description String?
  type        AppointmentType @default(outro)
  date        DateTime        @db.Date
  startTime   String?         @map("start_time")
  endTime     String?         @map("end_time")
  allDay      Boolean         @default(false) @map("all_day")
  color       String?
  completed   Boolean         @default(false)
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  lead        Lead?           @relation(fields: [leadId], references: [id])
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("appointments")
}

model CatalogCategory {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  name      String
  createdAt DateTime         @default(now()) @map("created_at")
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  products  CatalogProduct[]

  @@map("catalog_categories")
}

model CatalogProduct {
  id           String          @id @default(uuid())
  userId       String          @map("user_id")
  categoryId   String          @map("category_id")
  name         String
  price        Decimal         @db.Decimal(10, 2)
  durationDays Int?            @map("duration_days")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  category     CatalogCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  leadProducts LeadProduct[]

  @@map("catalog_products")
}

model LeadProduct {
  id        String         @id @default(uuid())
  leadId    String         @map("lead_id")
  productId String         @map("product_id")
  startDate DateTime       @map("start_date") @db.Date
  expiresAt DateTime?      @map("expires_at") @db.Date
  createdAt DateTime       @default(now()) @map("created_at")
  lead      Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  product   CatalogProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("lead_products")
}

model FinanceCategory {
  id           String          @id @default(uuid())
  userId       String          @map("user_id")
  name         String
  type         TransactionType
  color        String?
  createdAt    DateTime        @default(now()) @map("created_at")
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("finance_categories")
}

model Transaction {
  id          String          @id @default(uuid())
  userId      String          @map("user_id")
  categoryId  String          @map("category_id")
  type        TransactionType
  amount      Decimal         @db.Decimal(10, 2)
  description String?
  date        DateTime        @db.Date
  createdAt   DateTime        @default(now()) @map("created_at")
  category    FinanceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

enum Plan {
  free
  pro
}

enum LeadOrigin {
  indicacao
  instagram
  facebook
  whatsapp
  site
  telefone
  outro
}

enum FunnelStage {
  novo
  contatado
  negociando
  fechado
  perdido
}

enum AppointmentType {
  ligacao
  visita
  reuniao
  retorno
  outro
}

enum TransactionType {
  entrada
  saida
}
